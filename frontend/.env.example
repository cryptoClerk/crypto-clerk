# CryptoBooks Environment Variables

# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL="file:./dev.db"

# Supabase (for auth + PostgreSQL in production)
# SUPABASE_URL="https://your-project.supabase.co"
# SUPABASE_ANON_KEY="your-anon-key"
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Blockchain APIs (for real transaction data)
# ETHERSCAN_API_KEY="your-etherscan-api-key"
# POLYGONSCAN_API_KEY="your-polygonscan-api-key"
# BSCSCAN_API_KEY="your-bscscan-api-key"
# ARBISCAN_API_KEY="your-arbiscan-api-key"
# OPTIMISTIC_ETHERSCAN_API_KEY="your-optimistic-etherscan-api-key"

# CoinGecko (for USD price lookups)
# COINGECKO_API_KEY="your-coingecko-api-key"

# Stripe (for payments - Phase 3)
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# CORS (for API security)
# ALLOWED_ORIGIN="https://cryptobooks.app"
