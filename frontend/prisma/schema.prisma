generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String      @id @default(uuid())
  email           String      @unique
  name            String?
  businessName    String?
  businessAddress String?
  logoUrl         String?
  plan            String      @default("free") // free, pro, business
  createdAt       DateTime    @default(now())
  receipts        Receipt[]
  statements      Statement[]
  invoices        Invoice[]
  apiKeys         ApiKey[]
  
  // Usage tracking
  receiptsGenerated   Int     @default(0)
  statementsGenerated Int     @default(0)
  invoicesGenerated   Int     @default(0)
}

model Wallet {
  id        String   @id @default(uuid())
  address   String
  chain     String   // ethereum, polygon, bsc, etc.
  label     String?  // "Main Wallet", "DAO Payments"
  createdAt DateTime @default(now())
}

model Receipt {
  id              String   @id @default(uuid())
  txHash          String
  chain           String
  fromAddress     String
  toAddress       String
  amount          String   // store as string for precision
  token           String   // USDC, USDT, DAI, ETH
  usdValue        String?  // store as string for precision
  clientName      String
  description     String
  businessName    String?
  businessAddress String?
  date            DateTime
  pdfUrl          String?
  ipAddress       String?  // For free tier tracking (until auth is implemented)
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  invoiceId       String?  // linked to invoice if auto-generated from payment
  invoice         Invoice? @relation(fields: [invoiceId], references: [id])
  createdAt       DateTime @default(now())
}

model Statement {
  id              String   @id @default(uuid())
  startDate       String
  endDate         String
  chain           String
  totalTransactions Int
  totalIncome     String
  walletCount     Int
  pdfUrl          String?
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
}

model Invoice {
  id              String   @id @default(uuid())
  invoiceNumber   String   @unique
  clientName      String
  clientEmail     String?
  paymentAddress  String?  // The wallet address where payment is expected
  clientWallet    String?  // The wallet address we expect payment FROM (optional)
  amount          String   // store as string for precision
  token           String
  dueDate         DateTime?
  status          String   @default("pending") // pending, partial, paid, overpaid, overdue, cancelled
  paidAmount      String   @default("0") // running total of payments received
  remainingAmount String   @default("0") // how much is still owed
  paymentTxHash   String?
  pdfUrl          String?
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  receipts        Receipt[] // linked receipts
  createdAt       DateTime @default(now())
}

model CoinPrice {
  id              String   @id @default(uuid())
  contractAddress String   // lowercase
  chain           String   // ethereum, polygon, etc.
  date            String   // YYYY-MM-DD
  coinId          String?  // CoinGecko coin ID (e.g., "ethereum")
  symbol          String?  // token symbol (e.g., "ETH")
  priceUsd        String?  // price in USD at that date, null if not found
  source          String   @default("coingecko") // coingecko, fallback, manual
  fetchedAt       DateTime @default(now())
  
  @@unique([contractAddress, chain, date])
  @@index([contractAddress, chain, date])
}

model ApiKey {
  id        String   @id @default(uuid())
  key       String   @unique
  name      String   // "Production", "Development"
  lastUsed  DateTime?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}
